views:
  - type: cards
    name: Table
    filters:
      and:
        - file.hasTag("books")
    order:
      - file.name
      - tags
    image: note.banner
  - type: cards
    name: Learning how to learn
    filters:
      and:
        - file.hasTag("Metalearning")
    order:
      - file.name
      - tags
    sort:
      - property: file.ctime
        direction: DESC
    cardSize: 250
    image: note.banner
